{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@react-flowkit/typescript-config/react-library.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@react-flowkit/pubsub": [
        "./src/index.ts"
      ],
      "@react-flowkit/pubsub/react": [
        "./src/react.ts"
      ]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}